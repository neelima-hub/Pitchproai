                <ul class="space-y-2 mb-6 text-xs text-gray-300">
                  ${slide.bulletPoints.map((point: string) => `
                    <li class="flex items-start">
                      <span class="text-pitchpro-accent mr-2 shrink-0">•</span>
                      <span>${point}</span>
