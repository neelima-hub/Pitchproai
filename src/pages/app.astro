    <Sparkles class="h-4 w-4 text-pitchpro-accent" />
    <span id="toast-message" class="text-white">Action completed successfully</span>
  </div>

  <!-- Dynamic Dashboard Script -->
  <script>
    import { supabase } from '../lib/supabase';

    // Client-side authentication guard
    async function checkAuth() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login?redirect=/app';
      }
    }
    checkAuth();

    // Tab switching state
    let analysisState = 'idle'; // idle | analyzing | done
    let analyzedProjectTitle = 'PitchPro Presentation';
    let activeTabName = 'upload';

    // UI elements
    const tabButtons = document.querySelectorAll('.nav-item-btn');
    const tabPanels = document.querySelectorAll('.app-tab-panel');
    const unlockedBanner = document.getElementById('unlocked-banner');
    const closeBannerBtn = document.getElementById('close-banner');
    
    const navDeckBtn = document.getElementById('nav-deck') as HTMLButtonElement;
    const navCoachBtn = document.getElementById('nav-coach') as HTMLButtonElement;
    const navSummaryBtn = document.getElementById('nav-summary') as HTMLButtonElement;

    // App Sidebar Mobile Toggle logic
    const appSidebarToggle = document.getElementById('app-sidebar-toggle');
    const appSidebarMenu = document.getElementById('app-sidebar-menu');
    const appHamburgerIcon = document.getElementById('app-hamburger-icon');
    const appCloseIcon = document.getElementById('app-close-icon');

    if (appSidebarToggle && appSidebarMenu && appHamburgerIcon && appCloseIcon) {
      appSidebarToggle.addEventListener('click', () => {
        const isHidden = appSidebarMenu.classList.contains('hidden');
        if (isHidden) {
          appSidebarMenu.classList.remove('hidden');
          appSidebarMenu.classList.add('flex');
          appHamburgerIcon.classList.add('hidden');
          appCloseIcon.classList.remove('hidden');
        } else {
          appSidebarMenu.classList.add('hidden');
          appSidebarMenu.classList.remove('flex');
          appHamburgerIcon.classList.remove('hidden');
          appCloseIcon.classList.add('hidden');
        }
      });

      // Close menu on mobile when a tab selector button is clicked
      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          if (window.innerWidth < 768) {
            appSidebarMenu.classList.add('hidden');
            appSidebarMenu.classList.remove('flex');
            appHamburgerIcon.classList.remove('hidden');
            appCloseIcon.classList.add('hidden');
          }
        });
      });
    }

    // Toast function
    function showToast(msg: string) {
      const toast = document.getElementById('app-toast');
      const toastMsg = document.getElementById('toast-message');
      if (toast && toastMsg) {
        toastMsg.textContent = msg;
        toast.classList.remove('translate-y-20', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(() => {
          toast.classList.add('translate-y-20', 'opacity-0');
          toast.classList.remove('translate-y-0', 'opacity-100');
        }, 3000);
      }
    }

    // Tab switcher
    function switchTab(targetTab: string) {
      // Check if locked
      if (targetTab !== 'upload' && analysisState !== 'done') {
        showToast("Please run the AI Analysis first to unlock this feature!");
        return;
      }

      activeTabName = targetTab;

      // Update Nav Buttons
      tabButtons.forEach(btn => {
        const t = btn.getAttribute('data-tab');
        if (t === targetTab) {
          btn.classList.add('bg-white/10', 'text-white');
          btn.classList.remove('text-gray-400', 'hover:bg-white/5');
        } else {
          btn.classList.remove('bg-white/10', 'text-white');
          if (btn.hasAttribute('disabled')) {
            btn.classList.add('text-gray-400');
          } else {
            btn.classList.add('text-gray-400', 'hover:bg-white/5');
          }
        }
      });

      // Update Panels
      tabPanels.forEach(panel => {
        const p = panel.getAttribute('id');
        if (p === `tab-content-${targetTab}`) {
          panel.classList.remove('hidden');
          panel.classList.add('flex');
        } else {
          panel.classList.add('hidden');
          panel.classList.remove('flex');
        }
      });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-tab');
        if (target) switchTab(target);
      });
    });

    if (closeBannerBtn && unlockedBanner) {
      closeBannerBtn.addEventListener('click', () => {
        unlockedBanner.classList.add('hidden');
      });
    }

    // ==========================================
    // TAB 1: AI ANALYSIS SIMULATION
    // ==========================================
    const btnRunAnalysis = document.getElementById('btn-run-analysis');
    const textareaConcept = document.getElementById('concept-text') as HTMLTextAreaElement;
    const fileDropzone = document.getElementById('file-dropzone');
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const terminalLogs = document.getElementById('terminal-logs');
    const loaderRing = document.getElementById('loader-ring');
    const loaderIcon = document.getElementById('loader-icon');
    const loaderStatus = document.getElementById('loader-status');
    const loaderProgress = document.getElementById('loader-progress');
    const analysisBadge = document.getElementById('analysis-badge');

    // Drag-drop files mock
    if (fileDropzone && fileInput) {
      fileDropzone.addEventListener('click', () => fileInput.click());
      fileInput.addEventListener('change', () => {
        if (fileInput.files && fileInput.files[0]) {
          showToast(`File "${fileInput.files[0].name}" loaded! Ready for analysis.`);
          if (textareaConcept) {
            textareaConcept.value = `Uploaded Project Draft: ${fileInput.files[0].name}\nFile size: ${(fileInput.files[0].size / 1024).toFixed(1)} KB. Ready for AI Analysis extraction.`;
          }
        }
      });
    }

    function addLog(text: string, delay: number, nextCall: () => void) {
      setTimeout(() => {
        if (terminalLogs) {
          const row = document.createElement('p');
          row.className = 'text-green-400 font-mono animate-fade-in';
          row.innerHTML = `<span class="text-pitchpro-accent">&gt;</span> ${text}`;
          terminalLogs.appendChild(row);
          terminalLogs.scrollTop = terminalLogs.scrollHeight;
        }
        nextCall();
      }, delay);
    }

    if (btnRunAnalysis) {
      btnRunAnalysis.addEventListener('click', () => {
        if (analysisState === 'analyzing') return;
        
        analysisState = 'analyzing';
        if (analysisBadge) {
          analysisBadge.textContent = 'RUNNING';
          analysisBadge.className = 'text-[9px] bg-pitchpro-accent/20 text-pitchpro-accent px-1.5 py-0.5 rounded font-mono font-bold';
        }
        if (loaderRing) loaderRing.classList.add('animate-spin', 'border-t-pitchpro-accent');
        if (loaderIcon) loaderIcon.classList.add('text-pitchpro-accent');
        if (loaderStatus) loaderStatus.textContent = 'Ingesting Brief...';
        if (loaderProgress) loaderProgress.textContent = '10% complete';

        // Read title
        let textVal = textareaConcept ? textareaConcept.value : '';
        if (textVal.trim()) {
          const firstLine = textVal.split('\n')[0];
          if (firstLine.length < 40) analyzedProjectTitle = firstLine.replace(/Uploaded Project Draft:\s*/, '');
        }

        if (terminalLogs) terminalLogs.innerHTML = '<p class="text-gray-500">// Initiating compilation run...</p>';

        addLog("Initializing PitchPro AI Engine v4.0.2...", 500, () => {
          if (loaderStatus) loaderStatus.textContent = 'Parsing Problem Statements...';
          if (loaderProgress) loaderProgress.textContent = '35%';
          
          addLog("Parsing document syntax structures...", 800, () => {
            if (loaderStatus) loaderStatus.textContent = 'Evaluating Market Models...';
            if (loaderProgress) loaderProgress.textContent = '55%';
            
            addLog("Extracting problem statements & market TAM variables...", 800, () => {
              if (loaderStatus) loaderStatus.textContent = 'Synthesizing Deck Themes...';
              if (loaderProgress) loaderProgress.textContent = '75%';
              
              addLog("Configuring 6 slide layouts matching Obsidian theme...", 800, () => {
                if (loaderStatus) loaderStatus.textContent = 'Compiling Speech Cards...';
                if (loaderProgress) loaderProgress.textContent = '90%';
                
                addLog("Formulating speech transcripts & mock judge cards...", 700, () => {
                  if (loaderStatus) loaderStatus.textContent = 'Ready!';
                  if (loaderProgress) loaderProgress.textContent = '100% complete';
                  if (loaderRing) loaderRing.classList.remove('animate-spin');
                  if (loaderIcon) {
                    loaderIcon.classList.remove('text-pitchpro-accent');
                    loaderIcon.classList.add('text-pitchpro-success');
                  }
                  
                  analysisState = 'done';
                  if (analysisBadge) {
                    analysisBadge.textContent = 'COMPLETE';
                    analysisBadge.className = 'text-[9px] bg-pitchpro-success/20 text-pitchpro-success px-1.5 py-0.5 rounded font-mono font-bold';
                  }

                  // Enable navs
                  navDeckBtn.disabled = false;
                  navDeckBtn.classList.remove('opacity-60');
                  navDeckBtn.querySelector('.lock-icon')?.remove();

                  navCoachBtn.disabled = false;
                  navCoachBtn.classList.remove('opacity-60');
                  navCoachBtn.querySelector('.lock-icon')?.remove();

                  navSummaryBtn.disabled = false;
                  navSummaryBtn.classList.remove('opacity-60');
                  navSummaryBtn.querySelector('.lock-icon')?.remove();

                  // Banner
                  if (unlockedBanner) unlockedBanner.classList.remove('hidden');

                  // Inject title to deck title render
                  const deckTitleRender = document.getElementById('deck-title-render');
                  if (deckTitleRender) {
                    deckTitleRender.textContent = analyzedProjectTitle;
                  }

                  // Toast
                  showToast("Analysis Complete! All pitch materials unlocked.");
                  
                  // Auto-switch to deck tab
                  setTimeout(() => {
                    switchTab('deck');
                  }, 1000);
                });
              });
            });
          });
        });
      });
    }

    // ==========================================
    // TAB 2: SLIDE NAVIGATOR
    // ==========================================
    let currentSlideIndex = 0;
    const slideSelectorBtns = document.querySelectorAll('.slide-selector-btn');
    const slideCanvas = document.getElementById('slide-canvas');
    const slideCounterBadge = document.getElementById('slide-counter-badge');
    const slideDots = document.getElementById('slide-dots');
    const btnSlidePrev = document.getElementById('btn-slide-prev');
    const btnSlideNext = document.getElementById('btn-slide-next');
    const slideDynamicContent = document.getElementById('slide-dynamic-content');

    const slidesData = [
      {
        badge: "Startup pitch",
        title: "PitchPro: The AI-Powered Presentation Suite",
        desc: "Transforming raw technology specs, drafts, and case briefs into investor-winning pitches in minutes.",
        visual: `
          <div class="mt-4 flex space-x-2">
            <span class="bg-white/5 border border-white/10 px-3 py-1.5 rounded-lg text-[10px] text-gray-300">⚡ 10x Faster Build</span>
            <span class="bg-white/5 border border-white/10 px-3 py-1.5 rounded-lg text-[10px] text-gray-300">🎙️ Built-in Speech Rehearsal</span>
          </div>
        `
      },
      {
        badge: "The Problem",
        title: "The Innovation Translation Gap",
        desc: "Innovators construct brilliant architectures but fail to pitch their commercial benefit. VCs and judges pass on technologies they cannot quickly comprehend.",
        visual: `
          <div class="grid grid-cols-2 gap-4 mt-4">
            <div class="bg-white/5 p-3 rounded-xl border border-white/5">
              <span class="text-xs text-red-400 font-bold">$120B</span>
              <p class="text-[9px] text-gray-400 mt-1">Venture fund failures due to poor pitch clarity.</p>
            </div>
            <div class="bg-white/5 p-3 rounded-xl border border-white/5">
              <span class="text-xs text-red-400 font-bold">85%</span>
              <p class="text-[9px] text-gray-400 mt-1">Of judges indicate presentation delivery is key.</p>
            </div>
          </div>
        `
      },
      {
        badge: "The Solution",
        title: "PitchPro Automation",
        desc: "An automated compiler that turns complex text drafts into professional visuals, matching investor schemas, while analyzing vocal pacing in real-time.",
        visual: `
          <div class="space-y-2 mt-4 text-[10px]">
            <div class="flex items-center text-pitchpro-success">
              <span class="mr-2">✔</span> AI-parsed slides outline generator.
            </div>
            <div class="flex items-center text-pitchpro-success">
              <span class="mr-2">✔</span> Real-time transcription filler words scorer.
            </div>
          </div>
        `
      },
      {
        badge: "Market Sizing",
        title: "$8B Global Presentation Addressable Market",
        desc: "Starting with 15M early founders, hackathon participants, and academic researchers seeking grant funding globally.",
        visual: `
          <div class="space-y-2 mt-4">
            <div class="flex justify-between text-[9px] text-gray-400"><span>TAM (Global Presentations)</span><span>$8.0B</span></div>
            <div class="h-1 bg-white/10 rounded"><div class="h-full bg-pitchpro-accent w-[80%] rounded"></div></div>
            <div class="flex justify-between text-[9px] text-gray-400"><span>SAM (SaaS Founders & Hackers)</span><span>$1.2B</span></div>
            <div class="h-1 bg-white/10 rounded"><div class="h-full bg-pitchpro-success w-[30%] rounded"></div></div>
          </div>
        `
      },
      {
        badge: "Business Model",
        title: "SaaS Subscription Scaling",
        desc: "Free sandbox trials, Pro membership tiers for founders, and team accelerator licenses for incubators and university hubs.",
        visual: `
          <div class="grid grid-cols-3 gap-3 mt-4 text-center">
            <div class="bg-white/5 p-2 rounded-lg"><span class="block text-xs font-bold text-gray-400">Free</span><span class="text-[10px] text-gray-500">3 runs/mo</span></div>
            <div class="bg-pitchpro-accent/20 border border-pitchpro-accent/30 p-2 rounded-lg"><span class="block text-xs font-bold text-pitchpro-accent">Pro</span><span class="text-[10px] text-white">$19/mo</span></div>
            <div class="bg-white/5 p-2 rounded-lg"><span class="block text-xs font-bold text-gray-400">Team</span><span class="text-[10px] text-gray-500">Contact</span></div>
          </div>
        `
      },
      {
        badge: "The Ask",
        title: "Let's give great ideas the presentation they deserve.",
        desc: "We are currently opening integrations with academic accelerators and early-stage pre-seed cohorts.",
        visual: `
          <div class="mt-5">
            <a href="/app" class="inline-flex items-center text-xs font-bold bg-pitchpro-accent text-white px-4 py-2 rounded-xl">
              Start Building Now
            </a>
          </div>
        `
      }
    ];

    function renderSlide(index: number) {
      currentSlideIndex = index;

      // Update outline buttons
      slideSelectorBtns.forEach((btn, i) => {
        if (i === index) {
          btn.classList.add('border-pitchpro-accent', 'bg-pitchpro-accent/10', 'text-white');
          btn.classList.remove('border-white/5', 'hover:bg-white/5', 'text-gray-400');
          btn.querySelector('span')?.classList.remove('bg-white/10', 'text-gray-400');
          btn.querySelector('span')?.classList.add('bg-pitchpro-accent', 'text-white');
        } else {
          btn.classList.remove('border-pitchpro-accent', 'bg-pitchpro-accent/10', 'text-white');
          btn.classList.add('border-white/5', 'hover:bg-white/5', 'text-gray-400');
          btn.querySelector('span')?.classList.add('bg-white/10', 'text-gray-400');
          btn.querySelector('span')?.classList.remove('bg-pitchpro-accent', 'text-white');
        }
      });

      // Update counters & dots
      if (slideCounterBadge) slideCounterBadge.textContent = `SLIDE ${index + 1}/6`;
      if (slideDots) {
        slideDots.innerHTML = Array.from({ length: 6 }).map((_, i) => 
          `<span class="w-1.5 h-1.5 rounded-full ${i === index ? 'bg-pitchpro-accent' : 'bg-white/20'}"></span>`
        ).join('');
      }

      // Load Slide Content
      const data = slidesData[index];
      if (slideDynamicContent) {
        // Special replacement for Title cover slide
        const titleText = index === 0 ? analyzedProjectTitle : data.title;
        slideDynamicContent.innerHTML = `
          <div class="slide-page-element animate-fade-in">
            <div class="inline-block bg-pitchpro-accent/15 text-pitchpro-accent text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded-md mb-3 border border-pitchpro-accent/25">
              ${data.badge}
            </div>
            <h2 class="text-xl sm:text-2xl lg:text-3.5xl font-heading font-extrabold text-white leading-tight max-w-2xl mb-3">
              ${titleText}
            </h2>
            <p class="text-xs sm:text-sm text-gray-400 max-w-xl leading-relaxed">
              ${data.desc}
            </p>
            ${data.visual}
          </div>
        `;
      }
    }

    slideSelectorBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const slideIdx = parseInt(btn.getAttribute('data-slide') || '0');
        renderSlide(slideIdx);
      });
    });

    if (btnSlidePrev) {
      btnSlidePrev.addEventListener('click', () => {
        if (currentSlideIndex > 0) renderSlide(currentSlideIndex - 1);
      });
    }

    if (btnSlideNext) {
      btnSlideNext.addEventListener('click', () => {
        if (currentSlideIndex < 5) renderSlide(currentSlideIndex + 1);
      });
    }

    // Export buttons mock
    document.querySelectorAll('.btn-mock-export').forEach(btn => {
      btn.addEventListener('click', () => {
        showToast("Generating document file... Download will begin shortly.");
      });
    });

    // ==========================================
    // TAB 3: AI REHEARSAL COACH (MIC & SPEECH API)
    // ==========================================
    const btnCoachStart = document.getElementById('btn-coach-start') as HTMLButtonElement;
    const btnCoachStop = document.getElementById('btn-coach-stop') as HTMLButtonElement;
    const recIndicator = document.getElementById('coach-rec-indicator');
    const recDot = document.getElementById('rec-dot');
    const recText = document.getElementById('rec-text');
    const transcriptBox = document.getElementById('rehearsal-transcript-box');
    const micPrompt = document.getElementById('mic-prompt-text');
    const waveCanvas = document.getElementById('wave-canvas') as HTMLCanvasElement;

    // Scorecard Elements
    const coachScorecard = document.getElementById('coach-scorecard');
    const scoreTotal = document.getElementById('scorecard-total');
    const scoreTitle = document.getElementById('scorecard-title');
    const scoreDesc = document.getElementById('scorecard-desc');
    const scoreMeter1 = document.getElementById('score-meter-1');
    const scoreMeter1Val = document.getElementById('score-meter-1-val');
    const scoreMeter2 = document.getElementById('score-meter-2');
    const scoreMeter2Val = document.getElementById('score-meter-2-val');
    const scoreMeter3 = document.getElementById('score-meter-3');
    const scoreMeter3Val = document.getElementById('score-meter-3-val');
    const judgeQaContainer = document.getElementById('judge-qa-container');
    const unlockedTag = document.getElementById('scorecard-unlocked-tag');

    // Live Metrics Counters
    const metricWpm = document.getElementById('metric-wpm');
    const metricWpmLabel = document.getElementById('metric-wpm-label');
    const metricFillers = document.getElementById('metric-fillers');

    let recognition: any = null;
    let isRecording = false;
    let rehearsalText = '';
    let wordCount = 0;
    let timerInterval: any = null;
    let startTime = 0;
    let fillerCount = 0;

    // Audio Visualizer parameters
    let animationFrameId: number;
    let canvasCtx = waveCanvas ? waveCanvas.getContext('2d') : null;
    let audioContext: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let dataArray: Uint8Array | null = null;
    let stream: MediaStream | null = null;

    // Setup Canvas Resolution
    function resizeCanvas() {
      if (waveCanvas) {
        waveCanvas.width = waveCanvas.clientWidth;
        waveCanvas.height = waveCanvas.clientHeight;
      }
    }
    window.addEventListener('resize', resizeCanvas);
    setTimeout(resizeCanvas, 100);

    // Canvas sine wave mock animation
    let sineOffset = 0;
    function drawMockWave() {
      if (!canvasCtx || !waveCanvas) return;
      canvasCtx.clearRect(0, 0, waveCanvas.width, waveCanvas.height);
      
      const width = waveCanvas.width;
      const height = waveCanvas.height;
      const midY = height / 2;

      canvasCtx.lineWidth = 1.5;
      
      // Draw 3 layers of waves
      for (let w = 0; w < 3; w++) {
        canvasCtx.beginPath();
        const amplitude = isRecording ? (25 - w * 6) + Math.random() * 8 : 4;
        const speed = 0.08 + w * 0.02;
        const freq = 0.015 - w * 0.003;
        
        canvasCtx.strokeStyle = w === 0 
          ? 'rgba(108, 99, 255, 0.8)' 
          : w === 1 ? 'rgba(61, 220, 151, 0.4)' : 'rgba(255, 255, 255, 0.15)';

        for (let x = 0; x < width; x++) {
          const y = midY + Math.sin(x * freq + sineOffset * speed) * amplitude;
          if (x === 0) canvasCtx.moveTo(x, y);
          else canvasCtx.lineTo(x, y);
        }
        canvasCtx.stroke();
      }

      sineOffset += 1;
      animationFrameId = requestAnimationFrame(drawMockWave);
    }

    // Canvas real Audio Wave analysis
    function drawRealWave() {
      if (!canvasCtx || !waveCanvas || !analyser || !dataArray) return;
      canvasCtx.clearRect(0, 0, waveCanvas.width, waveCanvas.height);

      const bufferLength = analyser.frequencyBinCount;
      analyser.getByteTimeDomainData(dataArray as any);

      const width = waveCanvas.width;
      const height = waveCanvas.height;
      const midY = height / 2;

      canvasCtx.lineWidth = 2;
      canvasCtx.strokeStyle = '#6C63FF';
      canvasCtx.beginPath();

      const sliceWidth = width / bufferLength;
      let x = 0;

      for (let i = 0; i < bufferLength; i++) {
        const v = dataArray[i] / 128.0;
        const y = v * midY;

        if (i === 0) canvasCtx.moveTo(x, y);
        else canvasCtx.lineTo(x, y);

        x += sliceWidth;
      }

      canvasCtx.lineTo(width, midY);
      canvasCtx.stroke();

      animationFrameId = requestAnimationFrame(drawRealWave);
    }

    // Start listening
    async function startRecording() {
      isRecording = true;
      rehearsalText = '';
      wordCount = 0;
      fillerCount = 0;
      startTime = Date.now();

      if (micPrompt) micPrompt.classList.add('hidden');
      if (recDot) recDot.className = 'w-1.5 h-1.5 rounded-full bg-red-500 animate-ping mr-1.5';
      if (recText) recText.textContent = 'LISTENING';
      if (recIndicator) recIndicator.className = 'text-[9px] font-mono bg-red-500/10 text-red-400 px-2 py-0.5 rounded flex items-center border border-red-500/20';

      if (btnCoachStart) btnCoachStart.disabled = true;
      if (btnCoachStop) btnCoachStop.disabled = false;
      if (transcriptBox) transcriptBox.innerHTML = '<span class="text-white animate-pulse">Speak now: Microphone connection active...</span>';

      // Live metrics reset
      if (metricWpm) metricWpm.textContent = '0 WPM';
      if (metricWpmLabel) {
        metricWpmLabel.className = 'text-[9px] text-pitchpro-success font-semibold';
        metricWpmLabel.textContent = 'Cadence: Normal';
      }
      if (metricFillers) {
        metricFillers.textContent = '0';
        metricFillers.className = 'text-xl sm:text-2xl font-bold text-white mt-1';
      }

      // Initialize Web Audio API for real waves
      try {
        stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        // Create audio contexts
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        audioContext = new AudioContextClass();
        analyser = audioContext.createAnalyser();
        const source = audioContext.createMediaStreamSource(stream);
        source.connect(analyser);
        analyser.fftSize = 256;
        const bufferLength = analyser.frequencyBinCount;
        dataArray = new Uint8Array(bufferLength);
        
        cancelAnimationFrame(animationFrameId);
        drawRealWave();
      } catch (err) {
        // Fallback to beautiful simulated wave
        cancelAnimationFrame(animationFrameId);
        drawMockWave();
      }

      // Initialize Speech Recognition API
      const SpeechClass = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
      if (SpeechClass) {
        recognition = new SpeechClass();
        recognition.continuous = true;
        recognition.interimResults = true;
        recognition.lang = 'en-US';

        recognition.onresult = (event: any) => {
          let interimTranscript = '';
          let finalTranscript = '';

          for (let i = event.resultIndex; i < event.results.length; ++i) {
            const transcriptChunk = event.results[i][0].transcript;
            if (event.results[i].isFinal) {
              finalTranscript += transcriptChunk;
            } else {
              interimTranscript += transcriptChunk;
            }
          }

          if (finalTranscript || interimTranscript) {
            const currentStr = finalTranscript + interimTranscript;
            rehearsalText = currentStr;
            if (transcriptBox) transcriptBox.innerHTML = `<span class="text-white">${currentStr}</span>`;

            // Calculate words & pace
            const words = currentStr.trim().split(/\s+/).filter(Boolean);
            wordCount = words.length;

            const elapsedSec = (Date.now() - startTime) / 1000;
            const wpm = Math.round((wordCount / elapsedSec) * 60) || 0;
            if (metricWpm) metricWpm.textContent = `${wpm} WPM`;
            
            if (metricWpmLabel) {
              if (wpm > 155) {
                metricWpmLabel.textContent = 'Cadence: Too Fast';
                metricWpmLabel.className = 'text-[9px] text-red-400 font-semibold';
              } else if (wpm < 95 && wpm > 10) {
                metricWpmLabel.textContent = 'Cadence: Too Slow';
                metricWpmLabel.className = 'text-[9px] text-yellow-400 font-semibold';
              } else {
                metricWpmLabel.textContent = 'Cadence: Perfect';
                metricWpmLabel.className = 'text-[9px] text-pitchpro-success font-semibold';
              }
            }

            // Detect filler words (um, uh, like, so)
            const matches = currentStr.match(/\b(um|uh|like|so|basically)\b/gi);
            if (matches) {
              fillerCount = matches.length;
              if (metricFillers) {
                metricFillers.textContent = String(fillerCount);
                if (fillerCount > 5) {
                  metricFillers.className = 'text-xl sm:text-2xl font-bold text-red-400 mt-1';
                } else if (fillerCount > 2) {
                  metricFillers.className = 'text-xl sm:text-2xl font-bold text-yellow-400 mt-1';
                } else {
                  metricFillers.className = 'text-xl sm:text-2xl font-bold text-pitchpro-success mt-1';
                }
              }
            }
          }
        };

        recognition.onerror = () => {
          // Recognition error fallback
        };

        recognition.onend = () => {
          if (isRecording) recognition.start(); // Auto restart if continuous cuts
        };

        recognition.start();
      } else {
        // Speech API unsupported fallback simulator
        let step = 0;
        const mockPhrases = [
          "Hello and welcome, today I want to tell you about PitchPro...",
          "Hello and welcome, today I want to tell you about PitchPro. PitchPro is basically an AI platform...",
          "Hello and welcome, today I want to tell you about PitchPro. PitchPro is basically an AI platform that turns messy docs and like research paper folders into slides...",
          "Hello and welcome, today I want to tell you about PitchPro. PitchPro is basically an AI platform that turns messy docs and like research paper folders into slides. We also have this speech rehearsal dashboard, um, which gives speakers live telemetry feedback..."
        ];

        timerInterval = setInterval(() => {
          if (step < mockPhrases.length) {
            rehearsalText = mockPhrases[step];
            if (transcriptBox) {
              transcriptBox.innerHTML = `<span class="text-white">${rehearsalText}</span>`;
            }
            wordCount = rehearsalText.split(' ').length;
            const elapsed = (Date.now() - startTime) / 1000;
            const wpm = Math.round((wordCount / elapsed) * 60);
            if (metricWpm) metricWpm.textContent = `${wpm} WPM`;
            
            // Increment filler counts manually for mock
            if (step === 1) fillerCount = 1;
            if (step === 2) fillerCount = 2;
            if (step === 3) fillerCount = 4;
            
            if (metricFillers) {
              metricFillers.textContent = String(fillerCount);
              metricFillers.className = 'text-xl sm:text-2xl font-bold text-yellow-400 mt-1';
            }
            step++;
          }
        }, 3000);
      }
    }

    // Stop and compile
    function stopRecording() {
      isRecording = false;

      // Stop recognition
      if (recognition) {
        recognition.onend = null;
        recognition.stop();
      }
      if (timerInterval) clearInterval(timerInterval);

      // Stop audio stream
      if (stream) {
        stream.getTracks().forEach(track => track.stop());
      }
      if (audioContext) {
        audioContext.close();
      }

      cancelAnimationFrame(animationFrameId);
      if (canvasCtx && waveCanvas) {
        canvasCtx.clearRect(0, 0, waveCanvas.width, waveCanvas.height);
      }

      if (micPrompt) micPrompt.classList.remove('hidden');
      if (recDot) recDot.className = 'w-1.5 h-1.5 rounded-full bg-gray-500 mr-1.5';
      if (recText) recText.textContent = 'READY';
      if (recIndicator) recIndicator.className = 'text-[9px] font-mono bg-white/5 text-gray-400 px-2 py-0.5 rounded flex items-center';

      if (btnCoachStart) btnCoachStart.disabled = false;
      if (btnCoachStop) btnCoachStop.disabled = true;

      showToast("Speech analyzed! Scorecard calculated.");
      compileScorecard();
    }

    function compileScorecard() {
      // Unlock UI
      if (coachScorecard) coachScorecard.classList.remove('opacity-50');
      if (unlockedTag) {
        unlockedTag.textContent = 'UNLOCKED';
        unlockedTag.className = 'text-[9px] bg-pitchpro-success/20 text-pitchpro-success px-1.5 py-0.5 rounded font-mono font-bold';
      }

      // Calculate scores
      let finalScore = 88;
      let score1 = 86; // Clarity
      let score2 = 90; // Pace
      let score3 = 88; // Narrative

      if (fillerCount > 5) {
        finalScore -= 8;
        score1 -= 12;
      } else if (fillerCount > 2) {
        finalScore -= 3;
        score1 -= 5;
      }

      // Calculate based on word count / transcript
      const finalWords = rehearsalText.trim().split(/\s+/).filter(Boolean).length;
      const totalSec = (Date.now() - startTime) / 1000;
      const finalWpm = Math.round((finalWords / totalSec) * 60) || 120;

      if (finalWpm > 150) {
        score2 = 72;
        finalScore -= 6;
      } else if (finalWpm < 90 && finalWpm > 0) {
        score2 = 68;
        finalScore -= 8;
      } else {
        score2 = 95;
      }

      // Animate score elements
      if (scoreTotal) scoreTotal.textContent = String(finalScore);
      if (scoreTitle) scoreTitle.textContent = finalScore >= 85 ? 'Venture Ready!' : 'Good Effort';
      if (scoreDesc) {
        scoreDesc.textContent = finalScore >= 85 
          ? 'Exceptional speaking rhythm and clarity. Minor filler word reductions will push this to excellence.' 
          : 'Pacing rate fell outside the target 110-140 WPM range. Rehearse again to smooth out transitions.';
      }

      // Meters
      if (scoreMeter1) scoreMeter1.style.width = `${score1}%`;
      if (scoreMeter1Val) scoreMeter1Val.textContent = `${score1}%`;
      if (scoreMeter2) scoreMeter2.style.width = `${score2}%`;
      if (scoreMeter2Val) scoreMeter2Val.textContent = `${score2}%`;
      if (scoreMeter3) scoreMeter3.style.width = `${score3}%`;
      if (scoreMeter3Val) scoreMeter3Val.textContent = `${score3}%`;

      // Generate Mock Judge Questions
      if (judgeQaContainer) {
        judgeQaContainer.innerHTML = `
          <!-- Question 1 -->
          <div class="bg-white/5 border border-white/5 rounded-xl p-3 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all">
            <div class="flex items-start justify-between">
              <div>
                <span class="text-[8px] font-bold text-red-400 uppercase tracking-wide">Q1: Business Integration</span>
                <p class="text-[11px] font-semibold text-white mt-0.5">How will you secure academic user channels?</p>
                <p class="text-[10px] text-gray-400 hidden mt-2 pt-2 border-t border-white/5 font-normal leading-normal qa-answer">
                  "We coordinate directly with university grant programs, launching PitchPro as a sponsor utility for engineering hackathons to secure viral student integrations."
                </p>
              </div>
              <span class="text-xs text-gray-500 font-bold ml-2 shrink-0 group-hover/qa:text-white transition-colors">View Answer</span>
            </div>
          </div>

          <!-- Question 2 -->
          <div class="bg-white/5 border border-white/5 rounded-xl p-3 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all">
            <div class="flex items-start justify-between">
              <div>
                <span class="text-[8px] font-bold text-red-400 uppercase tracking-wide">Q2: Technological Defense</span>
                <p class="text-[11px] font-semibold text-white mt-0.5">What prevents Microsoft/Google from copying you?</p>
                <p class="text-[10px] text-gray-400 hidden mt-2 pt-2 border-t border-white/5 font-normal leading-normal qa-answer">
                  "While giants build broad tools, PitchPro is optimized specifically for competition metrics, packaging speech scoring with instant slide alignment tuned to venture capital schemas."
                </p>
              </div>
              <span class="text-xs text-gray-500 font-bold ml-2 shrink-0 group-hover/qa:text-white transition-colors">View Answer</span>
            </div>
          </div>
        `;

        // Answer toggle logic
        document.querySelectorAll('.group\\/qa').forEach(item => {
          item.addEventListener('click', () => {
            const answer = item.querySelector('.qa-answer');
            const viewText = item.querySelector('span:last-child');
            if (answer && viewText) {
              const isHidden = answer.classList.contains('hidden');
              if (isHidden) {
                answer.classList.remove('hidden');
                viewText.textContent = 'Hide';
              } else {
                answer.classList.add('hidden');
                viewText.textContent = 'View Answer';
              }
            }
          });
        });
      }
    }

    if (btnCoachStart) btnCoachStart.addEventListener('click', startRecording);
    if (btnCoachStop) btnCoachStop.addEventListener('click', stopRecording);

    // ==========================================
    // TAB 4: EXECUTIVE SUMMARY & COPY LOGIC
    // ==========================================
    const copyButtons = document.querySelectorAll('.btn-copy-text');
    copyButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const container = document.getElementById(targetId || '');
        if (container) {
          // Extract plain text content
          const text = container.innerText || container.textContent || '';
          navigator.clipboard.writeText(text).then(() => {
            showToast("Copied to clipboard successfully!");
            
            // Toggle copy icon to checkmark
            const originalHTML = btn.innerHTML;
            btn.innerHTML = `
              <span class="text-pitchpro-success flex items-center text-[10px] font-mono">
                Copied
              </span>
            `;
            setTimeout(() => {
              btn.innerHTML = originalHTML;
            }, 2000);
          }).catch(() => {
            showToast("Failed to copy automatically.");
          });
        }
      });
    });

  </script>

  <script>
    // Client-side script to wire up the frontend to the backend API routes and render payloads
    document.addEventListener('DOMContentLoaded', () => {
      const btnRunAnalysis = document.querySelector('#btn-run-analysis');
      const textareaConcept = document.querySelector('#concept-text') as HTMLTextAreaElement;
      const terminalLogs = document.querySelector('#terminal-logs');

      // Shared flag for unlocking tab transitions
      let generationDone = false;

      // Unlocking tabs logic
      const unlockTabs = () => {
        const tabs = ['deck', 'coach', 'summary'];
        tabs.forEach(tabName => {
          const btn = document.getElementById(`nav-${tabName}`);
          if (btn) {
            btn.removeAttribute('disabled');
            btn.classList.remove('opacity-60');
            btn.classList.add('hover:bg-white/5');
            btn.querySelector('.lock-icon')?.remove();
          }
        });

        // Show the top unlocked alert banner
        const unlockedBanner = document.getElementById('unlocked-banner');
        if (unlockedBanner) {
          unlockedBanner.classList.remove('hidden');
        }
      };

      // Toast function
      const showToastMessage = (msg: string) => {
        const toast = document.getElementById('app-toast');
        const toastMsg = document.getElementById('toast-message');
        if (toast && toastMsg) {
          toastMsg.textContent = msg;
          toast.classList.remove('translate-y-20', 'opacity-0');
          toast.classList.add('translate-y-0', 'opacity-100');
          
          setTimeout(() => {
            toast.classList.add('translate-y-20', 'opacity-0');
            toast.classList.remove('translate-y-0', 'opacity-100');
          }, 3000);
        }
      };

      // Override Tab Switcher Logic to bypass the old module-scoped block-check
      const tabButtons = document.querySelectorAll('.nav-item-btn');
      const tabPanels = document.querySelectorAll('.app-tab-panel');

      tabButtons.forEach(btn => {
        const newTabBtn = btn.cloneNode(true) as HTMLButtonElement;
        btn.parentNode?.replaceChild(newTabBtn, btn);
        
        newTabBtn.addEventListener('click', () => {
          const targetTab = newTabBtn.getAttribute('data-tab');
          if (!targetTab) return;
          
          if (targetTab !== 'upload' && !generationDone) {
            showToastMessage("Please run the AI Analysis first to unlock this feature!");
            return;
          }
          
          // Switch active state classes
          tabButtons.forEach(b => {
            const currentTab = b.getAttribute('data-tab');
            const actualBtn = document.getElementById(`nav-${currentTab}`) as HTMLButtonElement;
            if (actualBtn) {
              if (currentTab === targetTab) {
                actualBtn.classList.add('bg-white/10', 'text-white');
                actualBtn.classList.remove('text-gray-400', 'hover:bg-white/5');
              } else {
                actualBtn.classList.remove('bg-white/10', 'text-white');
                if (actualBtn.hasAttribute('disabled')) {
                  actualBtn.classList.add('text-gray-400');
                } else {
                  actualBtn.classList.add('text-gray-400', 'hover:bg-white/5');
                }
              }
            }
          });

          // Toggle panels
          tabPanels.forEach(panel => {
            if (panel.getAttribute('id') === `tab-content-${targetTab}`) {
              panel.classList.remove('hidden');
              panel.classList.add('flex');
            } else {
              panel.classList.add('hidden');
              panel.classList.remove('flex');
            }
          });
        });
      });

      // 1. Render function for the Pitch Deck (Grid of Slide Cards)
      const renderDeck = (deckJSON: any) => {
