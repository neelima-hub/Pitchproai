        }

        // Update titles on the page
        const deckTitleRender = document.getElementById('deck-title-render');
        if (deckTitleRender) {
          deckTitleRender.textContent = deckJSON.companyName;
        }
      };

      // 2. Render function for the Executive Summary
      const renderSummary = (companyName: string, summary: string, pitch: string) => {
        const execTextArea = document.getElementById('exec-text-area');
        const elevatorTextArea = document.getElementById('elevator-text-area');

        if (execTextArea) {
