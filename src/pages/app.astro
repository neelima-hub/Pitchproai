                  `).join('')}
                </ul>
              </div>

              <div class="mt-4 pt-4 border-t border-white/5 space-y-3 relative z-10">
                <div>
                  <span class="text-[9px] text-gray-500 font-mono uppercase block mb-1">Storytelling Purpose</span>
