          `;

          // Update word count label
          const elevatorCountElement = elevatorTextArea.closest('.bg-\\[\\#09090C\\]')?.querySelector('.border-t span:first-child');
          if (elevatorCountElement) {
            const words = pitch.trim().split(/\s+/).length;
            elevatorCountElement.textContent = `Words: ${words}`;
          }
        }
      };

      // 3. Render function for the Rehearsal Coach (predictedJudgeQuestions)
      const renderQA = (questions: any[]) => {
        const judgeQaContainer = document.getElementById('judge-qa-container');
        const coachScorecard = document.getElementById('coach-scorecard');
        const scorecardUnlockedTag = document.getElementById('scorecard-unlocked-tag');

        if (coachScorecard) {
          coachScorecard.classList.remove('opacity-50');
        }
        if (scorecardUnlockedTag) {
          scorecardUnlockedTag.textContent = 'UNLOCKED';
          scorecardUnlockedTag.className = 'text-[9px] bg-pitchpro-success/20 text-pitchpro-success px-1.5 py-0.5 rounded font-mono font-bold';
        }

        if (judgeQaContainer) {
          judgeQaContainer.innerHTML = questions.map((question: any) => `
            <div class="bg-white/5 border border-white/5 rounded-xl p-3 relative overflow-hidden group/qa cursor-pointer hover:bg-white/8 hover:border-white/10 transition-all mb-2.5">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <span class="text-[8px] font-bold text-red-400 uppercase tracking-wide block mb-1">
                    ${question.id} — Reason: ${question.reasonForAsking}
                  </span>
                  <p class="text-[11px] font-semibold text-white mt-0.5">${question.question}</p>
                  <p class="text-[10px] text-gray-400 hidden mt-2 pt-2 border-t border-white/5 font-normal leading-normal qa-answer">
                    <strong>Ideal Answer Framework:</strong> ${question.idealAnswerFramework}
                  </p>
                </div>
                <span class="text-xs text-gray-500 font-bold ml-2 shrink-0 group-hover/qa:text-white transition-colors select-none">View Details</span>
              </div>
            </div>
          `).join('');

          // Attach click listeners to Q&A items to toggle details
          judgeQaContainer.querySelectorAll('.group\\/qa').forEach(item => {
            item.addEventListener('click', () => {
              const answer = item.querySelector('.qa-answer');
              const viewText = item.querySelector('span:last-child');
              if (answer && viewText) {
                const isHidden = answer.classList.contains('hidden');
                if (isHidden) {
                  answer.classList.remove('hidden');
                  viewText.textContent = 'Hide';
                } else {
                  answer.classList.add('hidden');
                  viewText.textContent = 'View Details';
                }
              }
            });
          });
        }
      };

      if (btnRunAnalysis && textareaConcept && terminalLogs) {
        // Clone the button to remove all existing event listeners attached by the simulation script
        const newBtn = btnRunAnalysis.cloneNode(true) as HTMLButtonElement;
        btnRunAnalysis.parentNode?.replaceChild(newBtn, btnRunAnalysis);

        newBtn.addEventListener('click', async (e) => {
          e.preventDefault();

          const text = textareaConcept.value.trim();
          if (!text) {
            alert('Please enter a concept or idea first.');
            return;
          }

          // Disable button and show "Processing..." state
          newBtn.disabled = true;
          const originalHTML = newBtn.innerHTML;
          newBtn.innerHTML = '<span>Processing...</span>';

          // Clear terminal logs
          terminalLogs.innerHTML = '';

          const appendLog = (message: string, isError = false) => {
            const row = document.createElement('p');
            row.className = isError 
              ? 'text-red-500 font-mono animate-fade-in' 
              : 'text-green-400 font-mono';
            row.innerHTML = `<span class="text-pitchpro-accent">&gt;</span> ${message}`;
            terminalLogs.appendChild(row);
            terminalLogs.scrollTop = terminalLogs.scrollHeight;
          };

          try {
            // Log: Ingesting raw document...
            appendLog('// Ingesting raw document...');

            // Fetch generate-deck
            const deckRes = await fetch('/api/generate-deck', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ rawIdea: text, competitionFormat: 'Standard' })
            });

            if (!deckRes.ok) {
              const errData = await deckRes.json().catch(() => ({}));
              throw new Error(`Deck generation failed: ${errData.error || deckRes.statusText}`);
            }

            const deckJSON = await deckRes.json();

            // Log: Deck skeleton mapped. Generating assets & simulating judge panel...
            appendLog('// Deck skeleton mapped. Generating assets & simulating judge panel...');

            // Concurrently fetch generate-copy and generate-qa
            const [copyRes, qaRes] = await Promise.all([
              fetch('/api/generate-copy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ deckJSON })
              }),
              fetch('/api/generate-qa', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ deckJSON })
              })
            ]);

            if (!copyRes.ok) {
              const errData = await copyRes.json().catch(() => ({}));
              throw new Error(`Copy generation failed: ${errData.error || copyRes.statusText}`);
            }
            if (!qaRes.ok) {
              const errData = await qaRes.json().catch(() => ({}));
              throw new Error(`Q&A generation failed: ${errData.error || qaRes.statusText}`);
            }

            const copyJSON = await copyRes.json();
            const qaJSON = await qaRes.json();

            // Render all payloads to the DOM
            renderDeck(deckJSON);
            renderSummary(deckJSON.companyName, copyJSON.executiveSummary, copyJSON.elevatorPitch);
            renderQA(qaJSON.predictedJudgeQuestions);

            // Log: Generation Complete. Assets unlocked.
            appendLog('// Generation Complete. Assets unlocked.');

            // Unlock the dashboard tabs
            generationDone = true;
            unlockTabs();
            showToastMessage("Analysis Complete! All pitch materials unlocked.");

          } catch (error: any) {
            console.error('API Interactivity Error:', error);
            appendLog(`Error: ${error.message || error}`, true);
          } finally {
            // Re-enable button and reset its text
            newBtn.disabled = false;
            newBtn.innerHTML = originalHTML;
          }
        });
      }
    });
  </script>

</Layout>
