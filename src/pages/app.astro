        if (deckWorkspaceGrid) {
          deckWorkspaceGrid.className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6";
          deckWorkspaceGrid.innerHTML = deckJSON.slides.map((slide: any) => `
            <div class="bg-[#0B0B0F] border border-gray-800 rounded-2xl p-6 flex flex-col justify-between shadow-xl relative overflow-hidden">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(108,99,255,0.05),transparent_60%)] pointer-events-none"></div>
              
              <div class="relative z-10">
                <div class="flex items-center justify-between pb-3 border-b border-white/10 mb-4">
