                <div class="bg-white/[0.02] border border-white/5 rounded-xl p-3">
                  <span class="text-[9px] text-pitchpro-accent font-mono uppercase block mb-1">Visual Recommendation</span>
                  <p class="text-xs text-gray-400 leading-normal">
                    ${slide.visualRecommendation}
