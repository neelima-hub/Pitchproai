---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign In - PitchPro" description="Access your PitchPro account to transform raw ideas into winning pitches.">
  <div class="relative min-h-screen flex flex-col justify-center items-center px-4 py-12 overflow-hidden bg-pitchpro-dark">
    
    <!-- Background Glow Effects -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-pitchpro-accent/15 rounded-full blur-[120px] pointer-events-none z-0"></div>
    <div class="absolute bottom-10 left-10 w-[250px] h-[250px] bg-pitchpro-accent/5 rounded-full blur-[80px] pointer-events-none z-0"></div>

    <!-- Inner Wrapper -->
    <div class="w-full max-w-md z-10">
      
      <!-- Top Logo / Home Link -->
      <div class="flex justify-center mb-8 animate-fade-in" style="animation-delay: 100ms;">
        <a href="/" class="flex items-center space-x-3 group">
          <img 
            src="/logo.jpeg" 
            alt="PitchPro Logo" 
            class="h-9 w-9 sm:h-10 sm:w-10 rounded-lg object-cover border border-pitchpro-accent/20 shadow-sm transition-transform group-hover:scale-105" 
          />
          <span class="font-heading font-bold text-xl sm:text-2xl tracking-tight bg-gradient-to-r from-white via-pitchpro-accent to-pitchpro-accent bg-clip-text text-transparent">
            PitchPro
          </span>
        </a>
      </div>

      <!-- Auth Card -->
      <div class="glass-dark p-8 sm:p-10 rounded-2xl border border-white/10 shadow-2xl relative overflow-hidden animate-fade-in" style="animation-delay: 200ms;">
        
        <div class="text-center mb-8">
          <h1 id="auth-title" class="text-2xl sm:text-3xl font-heading font-bold text-white tracking-tight">Welcome back</h1>
          <p id="auth-subtitle" class="text-sm text-gray-400 mt-2">Enter your credentials to access your account</p>
        </div>

        <!-- Notification Banner -->
        <div id="alert-banner" class="hidden mb-6 p-4 rounded-xl border text-sm animate-fade-in transition-all duration-300">
          <div class="flex items-start gap-3">
            <span id="alert-icon" class="mt-0.5 flex-shrink-0"></span>
            <div id="alert-message" class="font-medium flex-grow break-words"></div>
          </div>
        </div>

        <!-- Authentication Form -->
        <form id="auth-form" class="space-y-5">
          <!-- Full Name Input (Hidden by default, shown for Sign Up) -->
          <div id="name-container" class="hidden transition-all duration-300">
            <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Full Name</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-500">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="John Doe" 
                class="w-full pl-11 pr-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 text-sm focus:border-pitchpro-accent focus:ring-2 focus:ring-pitchpro-accent/20 focus:outline-none transition-all duration-200"
              />
            </div>
          </div>

          <!-- Email Input -->
          <div>
            <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Email Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-500">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
                </svg>
              </div>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="name@example.com" 
                class="w-full pl-11 pr-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 text-sm focus:border-pitchpro-accent focus:ring-2 focus:ring-pitchpro-accent/20 focus:outline-none transition-all duration-200"
              />
            </div>
          </div>

          <!-- Password Input -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-gray-400">Password</label>
              <a href="#" id="forgot-password-link" class="text-xs font-medium text-pitchpro-accent hover:underline">Forgot password?</a>
            </div>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-500">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <input 
                type="password" 
                id="password" 
                name="password" 
                required 
                placeholder="••••••••" 
                class="w-full pl-11 pr-12 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 text-sm focus:border-pitchpro-accent focus:ring-2 focus:ring-pitchpro-accent/20 focus:outline-none transition-all duration-200"
              />
              <button 
                type="button" 
                id="toggle-password" 
                class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-gray-500 hover:text-gray-300 focus:outline-none transition-colors"
                aria-label="Toggle password visibility"
              >
                <svg id="eye-icon-show" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                <svg id="eye-icon-hide" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="submit-btn" 
            class="w-full py-3 px-4 bg-pitchpro-accent hover:bg-pitchpro-accent-hover active:scale-[0.98] text-white font-medium rounded-xl transition-all duration-200 shadow-lg shadow-pitchpro-accent/25 hover:shadow-pitchpro-accent/40 flex items-center justify-center gap-2 cursor-pointer focus:outline-none focus:ring-2 focus:ring-pitchpro-accent/50"
          >
            <span id="btn-text">Sign In</span>
            <!-- Spinner -->
            <svg id="btn-spinner" class="animate-spin h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>

        <!-- Divider -->
        <div id="social-auth-divider" class="relative my-6 flex items-center">
          <div class="flex-grow border-t border-white/10"></div>
          <span class="flex-shrink mx-4 text-xs text-gray-500 uppercase tracking-wider">or continue with</span>
          <div class="flex-grow border-t border-white/10"></div>
        </div>

        <!-- Social logins -->
        <div id="social-auth-container" class="grid grid-cols-2 gap-3">
          <button 
            type="button" 
            class="flex items-center justify-center gap-2 py-2.5 px-4 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 text-white font-medium text-sm transition-all duration-200 active:scale-[0.98]"
            onclick="alert('Social sign-in is not configured. Please use email and password.')"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Google
          </button>
          <button 
            type="button" 
            class="flex items-center justify-center gap-2 py-2.5 px-4 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 text-white font-medium text-sm transition-all duration-200 active:scale-[0.98]"
            onclick="alert('Social sign-in is not configured. Please use email and password.')"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
            GitHub
          </button>
        </div>

      </div>

      <!-- Toggle Mode Link -->
      <p class="text-center text-xs text-gray-500 mt-6 animate-fade-in" style="animation-delay: 300ms;">
        <span id="footer-text-label">Don't have an account?</span>
        <button 
          type="button" 
          id="toggle-auth-mode" 
          class="text-pitchpro-accent hover:underline font-medium ml-1 bg-transparent border-0 cursor-pointer focus:outline-none"
        >Create one for free</button>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  let isSignUp = false;

  const form = document.getElementById('auth-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as unknown as SVGElement;
  
  const authTitle = document.getElementById('auth-title') as HTMLHeadingElement;
  const authSubtitle = document.getElementById('auth-subtitle') as HTMLParagraphElement;
  const nameContainer = document.getElementById('name-container') as HTMLDivElement;
  const nameInput = document.getElementById('name') as HTMLInputElement;
  const forgotPasswordLink = document.getElementById('forgot-password-link') as HTMLAnchorElement;

  const footerTextLabel = document.getElementById('footer-text-label') as HTMLSpanElement;
  const toggleAuthModeBtn = document.getElementById('toggle-auth-mode') as HTMLButtonElement;

  const alertBanner = document.getElementById('alert-banner') as HTMLDivElement;
  const alertMessage = document.getElementById('alert-message') as HTMLDivElement;
  const alertIcon = document.getElementById('alert-icon') as HTMLSpanElement;

  const togglePasswordBtn = document.getElementById('toggle-password') as HTMLButtonElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const eyeIconShow = document.getElementById('eye-icon-show') as unknown as SVGElement;
  const eyeIconHide = document.getElementById('eye-icon-hide') as unknown as SVGElement;

  // Toggle Password Visibility
  if (togglePasswordBtn && passwordInput && eyeIconShow && eyeIconHide) {
    togglePasswordBtn.addEventListener('click', () => {
      const isPassword = passwordInput.getAttribute('type') === 'password';
      passwordInput.setAttribute('type', isPassword ? 'text' : 'password');
      if (isPassword) {
        eyeIconShow.classList.add('hidden');
        eyeIconHide.classList.remove('hidden');
      } else {
        eyeIconShow.classList.remove('hidden');
        eyeIconHide.classList.add('hidden');
      }
    });
  }

  // Toggle Auth Mode (Sign In vs Sign Up)
  if (toggleAuthModeBtn && authTitle && authSubtitle && nameContainer && nameInput && forgotPasswordLink && btnText && footerTextLabel) {
    toggleAuthModeBtn.addEventListener('click', () => {
      isSignUp = !isSignUp;
      hideAlert();

      if (isSignUp) {
        authTitle.textContent = 'Create account';
        authSubtitle.textContent = 'Get started with your free PitchPro account';
        nameContainer.classList.remove('hidden');
        nameInput.required = true;
        forgotPasswordLink.classList.add('invisible'); // Hide forgot password during signup
        btnText.textContent = 'Create Account';
        footerTextLabel.textContent = 'Already have an account?';
        toggleAuthModeBtn.textContent = 'Sign in';
      } else {
        authTitle.textContent = 'Welcome back';
        authSubtitle.textContent = 'Enter your credentials to access your account';
        nameContainer.classList.add('hidden');
        nameInput.required = false;
        nameInput.value = '';
        forgotPasswordLink.classList.remove('invisible');
        btnText.textContent = 'Sign In';
        footerTextLabel.textContent = "Don't have an account?";
        toggleAuthModeBtn.textContent = 'Create one for free';
      }
    });
  }

  // Display alert banner helper
  function showAlert(message: string, type: 'error' | 'success') {
    if (!alertBanner || !alertMessage || !alertIcon) return;

    alertBanner.className = 'mb-6 p-4 rounded-xl border text-sm animate-fade-in transition-all duration-300 flex items-start gap-3';
    alertMessage.textContent = message;

    if (type === 'error') {
      alertBanner.classList.add('bg-red-500/10', 'border-red-500/20', 'text-red-400');
      alertIcon.innerHTML = `
        <svg class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      `;
    } else {
      alertBanner.classList.add('bg-pitchpro-success/10', 'border-pitchpro-success/20', 'text-pitchpro-success');
      alertIcon.innerHTML = `
        <svg class="h-5 w-5 text-pitchpro-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      `;
    }

    alertBanner.classList.remove('hidden');
  }

  function hideAlert() {
    if (alertBanner) {
      alertBanner.classList.add('hidden');
    }
  }

  // Get redirect path from query param
  function getRedirectPath() {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.get('redirect') || '/app';
  }

  // Form submission handler
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;
      
      const email = emailInput?.value.trim();
      const password = passwordInput?.value;
      const name = nameInput?.value.trim();

      if (!email || !password || (isSignUp && !name)) {
        showAlert('Please fill in all required fields.', 'error');
        return;
      }

      // Start Loading state
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = isSignUp ? 'Creating account...' : 'Signing in...';
      if (btnSpinner) btnSpinner.classList.remove('hidden');
      hideAlert();

      try {
        if (isSignUp) {
          // Sign Up
          const { data, error } = await supabase.auth.signUp({
            email,
            password,
            options: {
              data: {
                full_name: name
              }
            }
          });

          if (error) {
            showAlert(error.message || 'Registration failed. Please try again.', 'error');
            if (submitBtn) submitBtn.disabled = false;
            if (btnText) btnText.textContent = 'Create Account';
            if (btnSpinner) btnSpinner.classList.add('hidden');
          } else {
            // Check if user is logged in automatically (depends on Supabase settings)
            const session = data?.session;
            if (session) {
              showAlert('Registration successful! Logging you in...', 'success');
              setTimeout(() => {
                window.location.href = getRedirectPath();
              }, 1000);
            } else {
              showAlert('Account created successfully! Please check your email for a confirmation link to activate your account.', 'success');
              if (submitBtn) submitBtn.disabled = false;
              if (btnText) btnText.textContent = 'Create Account';
              if (btnSpinner) btnSpinner.classList.add('hidden');
              // Clear fields
              if (nameInput) nameInput.value = '';
              if (emailInput) emailInput.value = '';
              if (passwordInput) passwordInput.value = '';
            }
          }
        } else {
          // Sign In
          const { data, error } = await supabase.auth.signInWithPassword({
            email,
            password
          });

          if (error) {
            showAlert(error.message || 'Authentication failed. Please verify your credentials.', 'error');
            if (submitBtn) submitBtn.disabled = false;
            if (btnText) btnText.textContent = 'Sign In';
            if (btnSpinner) btnSpinner.classList.add('hidden');
          } else {
            showAlert('Login successful! Redirecting...', 'success');
            setTimeout(() => {
              window.location.href = getRedirectPath();
            }, 800);
          }
        }
      } catch (err: any) {
        console.error('Authentication error:', err);
        showAlert('An unexpected error occurred. Please try again.', 'error');
        if (submitBtn) submitBtn.disabled = false;
        if (btnText) btnText.textContent = isSignUp ? 'Create Account' : 'Sign In';
        if (btnSpinner) btnSpinner.classList.add('hidden');
      }
    });
  }
</script>
