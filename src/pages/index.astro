---
import Layout from '../layouts/Layout.astro';
import { 
  FileText, 
  Sparkles, 
  Layers, 
  Mic, 
  ArrowRight, 
  Play, 
  CheckCircle2, 
  Target,
  Trophy,
  Zap,
  Users,
  Compass,
  ArrowUpRight
} from 'lucide-astro';
---

<Layout title="PitchPro - Transform Raw Ideas into Winning Pitches">
  
  <!-- Navigation Header -->
  <header class="fixed top-0 left-0 right-0 z-50 glass-dark border-b border-white/10 shadow-lg transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 sm:h-20">
        
        <!-- Logo -->
        <a href="/" class="flex items-center space-x-3 group">
          <img 
            src="/logo.jpeg" 
            alt="PitchPro Logo" 
            class="h-9 w-9 sm:h-10 sm:w-10 rounded-lg object-cover border border-pitchpro-accent/20 shadow-sm transition-transform group-hover:scale-105" 
          />
          <span class="font-heading font-bold text-xl sm:text-2xl tracking-tight bg-gradient-to-r from-white via-pitchpro-accent to-pitchpro-accent bg-clip-text text-transparent">
            PitchPro
          </span>
        </a>

        <!-- Desktop Navigation Links -->
        <nav class="hidden md:flex items-center space-x-8">
          <a href="#how-it-works" class="text-sm font-medium text-gray-300 hover:text-pitchpro-accent transition-colors">How It Works</a>
          <a href="#features" class="text-sm font-medium text-gray-300 hover:text-pitchpro-accent transition-colors">Features</a>
          <a href="#audiences" class="text-sm font-medium text-gray-300 hover:text-pitchpro-accent transition-colors">Who It's For</a>
        </nav>

        <!-- CTAs -->
        <div class="hidden md:flex items-center space-x-3 sm:space-x-4">
          <a 
            href="/login" 
            class="text-sm font-semibold text-gray-300 hover:text-white transition-colors px-3 py-2"
          >
            Sign In
          </a>
          <a 
            href="/app" 
            class="inline-flex items-center justify-center text-sm font-semibold text-white bg-pitchpro-accent hover:bg-pitchpro-accent-hover px-4 py-2 sm:px-5 sm:py-2.5 rounded-xl shadow-md shadow-pitchpro-accent/15 hover:shadow-lg hover:shadow-pitchpro-accent/25 transition-all hover:-translate-y-0.5"
          >
            Start Building
            <ArrowRight class="ml-1.5 h-4 w-4" />
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-btn" 
          class="flex md:hidden items-center justify-center p-2 rounded-xl text-gray-300 hover:text-pitchpro-accent hover:bg-white/5 transition-all focus:outline-none"
          aria-label="Toggle Menu"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu Panel (hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden bg-[#0B0B0F]/95 backdrop-blur-md border-t border-white/10 px-4 py-6 space-y-4">
      <nav class="flex flex-col space-y-3">
        <a href="#how-it-works" class="mobile-nav-link text-base font-semibold text-gray-300 hover:text-pitchpro-accent transition-colors py-2 px-3 rounded-lg hover:bg-white/5">How It Works</a>
        <a href="#features" class="mobile-nav-link text-base font-semibold text-gray-300 hover:text-pitchpro-accent transition-colors py-2 px-3 rounded-lg hover:bg-white/5">Features</a>
        <a href="#audiences" class="mobile-nav-link text-base font-semibold text-gray-300 hover:text-pitchpro-accent transition-colors py-2 px-3 rounded-lg hover:bg-white/5">Who It's For</a>
      </nav>
      <div class="pt-4 border-t border-white/10 flex flex-col gap-3">
        <a 
          href="/login" 
          class="inline-flex items-center justify-center text-base font-semibold text-gray-300 hover:text-white bg-white/5 hover:bg-white/10 py-3 rounded-xl transition-all"
        >
          Sign In
        </a>
        <a 
          href="/app" 
          class="inline-flex items-center justify-center text-base font-bold text-white bg-pitchpro-accent hover:bg-pitchpro-accent-hover py-3 rounded-xl shadow-md shadow-pitchpro-accent/15 transition-all"
        >
          Start Building
          <ArrowRight class="ml-1.5 h-4 w-4" />
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden bg-gradient-to-b from-[#0B0B0F] via-[#0B0B0F]/95 to-[#0B0B0F] border-b border-white/10">
    <!-- Grid overlay & glow blobs -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-30"></div>
    <div class="absolute top-12 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-pitchpro-accent/10 blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      
      <!-- Top Badge -->
      <div class="inline-flex items-center space-x-2 bg-pitchpro-accent/8 border border-pitchpro-accent/15 px-3 py-1.5 rounded-full mb-6 sm:mb-8 animate-fade-in">
        <Sparkles class="h-4 w-4 text-pitchpro-accent" />
        <span class="text-xs font-semibold text-pitchpro-accent tracking-wide uppercase">AI-Powered Rehearsal & Pitch Deck Suite</span>
      </div>

      <!-- Main Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold tracking-tight text-white max-w-4xl mx-auto leading-[1.1] mb-6 sm:mb-8">
        Give Your Ideas the <span class="bg-gradient-to-r from-pitchpro-accent via-indigo-500 to-indigo-600 bg-clip-text text-transparent">Presentation</span> They Deserve.
      </h1>

      <!-- Subheadline -->
      <p class="text-base sm:text-lg lg:text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-8 sm:mb-10">
        PitchPro transforms raw ideas, research papers, and startup concepts into investor-ready slide decks, summaries, and speech outlines. Rehearse live with our AI mock judge.
      </p>

      <!-- CTAs -->
      <div class="flex items-center justify-center mb-14 sm:mb-20">
        <a 
          href="/app" 
          class="w-full sm:w-auto inline-flex items-center justify-center text-base font-bold text-white bg-pitchpro-accent hover:bg-pitchpro-accent-hover px-7 py-3.5 rounded-xl shadow-lg shadow-pitchpro-accent/20 hover:shadow-xl hover:shadow-pitchpro-accent/30 transition-all hover:-translate-y-0.5"
        >
          Start Building for Free
          <ArrowRight class="ml-2 h-5 w-5" />
        </a>
      </div>

      <!-- Interactive Mockup Image Area -->
      <div class="relative max-w-5xl mx-auto rounded-2xl border border-white/10 bg-white/[0.02] p-2 sm:p-3 shadow-2xl shadow-black/40">
        <div class="absolute inset-0 bg-gradient-to-tr from-pitchpro-accent/5 to-pitchpro-success/5 rounded-2xl pointer-events-none"></div>
        
        <!-- Mock App Dashboard Browser Window -->
        <div class="rounded-xl overflow-hidden border border-white/5 bg-[#08080C] aspect-[3/4] sm:aspect-[16/10] lg:aspect-[16/9] flex flex-col">
          <!-- Browser Top bar -->
          <div class="bg-[#0B0B0F] border-b border-white/5 px-4 py-3 flex items-center justify-between shrink-0">
            <div class="flex items-center space-x-2">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="w-48 sm:w-72 bg-white/5 rounded-md text-[10px] text-gray-500 py-1 text-center truncate">
              pitchpro.ai/app/dashboard
            </div>
            <div class="w-10"></div>
          </div>
          
          <!-- Mock content showing document transformation -->
          <div class="flex-1 p-4 sm:p-6 grid grid-cols-1 md:grid-cols-2 gap-4 overflow-hidden text-left relative">
            
            <!-- Left Side: Input Document -->
            <div class="bg-[#0B0B0F] rounded-xl border border-white/10 p-4 shadow-sm flex flex-col justify-between relative overflow-hidden h-full">
              <div class="absolute top-0 right-0 bg-pitchpro-accent/10 text-pitchpro-accent px-3 py-1 text-[10px] font-bold rounded-bl-lg">
                Source Document
              </div>
              <div>
                <div class="flex items-center space-x-2 mb-3">
                  <FileText class="h-5 w-5 text-pitchpro-accent" />
                  <span class="font-heading font-semibold text-xs text-gray-200">ProjectBrief_PitchPro.docx</span>
                </div>
                <div class="space-y-2 text-[10px] text-gray-500 font-mono">
                  <p class="text-gray-400 font-semibold text-[11px] mb-1"># Startup Overview & Value Prop</p>
                  <p>PitchPro is a platform that uses generative AI models to help founders and researchers build pitch presentations quickly...</p>
                  <p class="text-gray-400 font-semibold text-[11px] mt-2 mb-1"># Core Problem</p>
                  <p>Most early-stage innovators fail to communicate their technical ideas clearly to judges and business investors, resulting in lost grants and venture capital funding...</p>
                </div>
              </div>
              <div class="mt-4 pt-3 border-t border-white/5 flex justify-between items-center">
                <span class="text-[9px] text-gray-500">Size: 42.4 KB</span>
                <span class="text-[9px] font-semibold text-pitchpro-success flex items-center">
                  <CheckCircle2 class="h-3 w-3 mr-1" />
                  File uploaded successfully
                </span>
              </div>
            </div>

            <!-- Arrow Indicator (Only visible on MD screens) -->
            <div class="hidden md:flex absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 w-10 h-10 rounded-full bg-pitchpro-accent text-white items-center justify-center shadow-lg border-2 border-[#0B0B0F]">
              <Sparkles class="h-5 w-5 animate-pulse" />
            </div>

            <!-- Right Side: AI Output Presentation -->
            <div class="bg-[#111116] text-white rounded-xl border border-white/10 p-4 shadow-sm flex flex-col justify-between h-full relative">
              <div class="absolute top-0 right-0 bg-pitchpro-success/20 text-pitchpro-success px-3 py-1 text-[10px] font-bold rounded-bl-lg">
                Generated Pitch Deck
              </div>
              <div>
                <div class="flex items-center space-x-2 mb-3">
                  <Layers class="h-4 w-4 text-pitchpro-accent" />
                  <span class="font-heading font-semibold text-[10px] text-gray-500">Slide 2 of 10: Problem Statement</span>
                </div>
                
                <!-- Mock Slide Preview -->
                <div class="bg-white/5 border border-white/10 rounded-lg p-3 my-2">
                  <p class="text-[11px] font-semibold text-pitchpro-success tracking-wide uppercase mb-1">The Core Friction</p>
                  <h3 class="font-heading font-bold text-sm sm:text-base text-white mb-2 leading-tight">
                    The Innovation Translation Gap
                  </h3>
                  <p class="text-[10px] text-gray-300 leading-normal">
                    Brilliant builders struggle to frame technical breakthroughs into commercial business opportunities that investors understand.
                  </p>
                  
                  <div class="grid grid-cols-2 gap-2 mt-3">
                    <div class="bg-white/5 p-1.5 rounded text-center">
                      <p class="text-[12px] font-bold text-pitchpro-accent">$120B</p>
                      <p class="text-[7px] text-gray-400">Annual Venture Failures</p>
                    </div>
                    <div class="bg-white/5 p-1.5 rounded text-center">
                      <p class="text-[12px] font-bold text-pitchpro-accent">70%</p>
                      <p class="text-[7px] text-gray-400">Due to Poor Narrative</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="pt-2 flex justify-between items-center text-[9px]">
                <span class="text-gray-500">Template: Carbon Tech Premium</span>
                <span class="text-pitchpro-accent font-semibold flex items-center">
                  Preview Dashboard
                  <ArrowRight class="h-3 w-3 ml-0.5" />
                </span>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Social Proof / Audience Bar -->
  <section class="border-b border-white/10 bg-[#111116] py-10 relative overflow-hidden pause-marquee">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold text-gray-400 uppercase tracking-widest mb-6">
        PitchPro empowers innovators across top organizations
      </p>
    </div>
    
    <div class="relative w-full overflow-hidden flex select-none">
      <!-- Gradient masks for fade effect at edges -->
      <div class="absolute inset-y-0 left-0 w-20 sm:w-32 bg-gradient-to-r from-[#111116] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-20 sm:w-32 bg-gradient-to-l from-[#111116] to-transparent z-10 pointer-events-none"></div>
      
      <!-- Scrolling Track Group 1 -->
      <div class="flex shrink-0 items-center justify-around min-w-full gap-8 sm:gap-16 animate-marquee py-2 pr-8 sm:pr-16">
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Trophy class="h-5 w-5 mr-2 text-pitchpro-accent" /> Stanford Startup
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Zap class="h-5 w-5 mr-2 text-pitchpro-accent" /> Y Combinator Prep
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Users class="h-5 w-5 mr-2 text-pitchpro-accent" /> Hackathon Hubs
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Compass class="h-5 w-5 mr-2 text-pitchpro-accent" /> Techstars Alumni
        </span>
      </div>
      
      <!-- Scrolling Track Group 2 (Duplicated for seamless looping) -->
      <div class="flex shrink-0 items-center justify-around min-w-full gap-8 sm:gap-16 animate-marquee py-2 pr-8 sm:pr-16" aria-hidden="true">
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Trophy class="h-5 w-5 mr-2 text-pitchpro-accent" /> Stanford Startup
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Zap class="h-5 w-5 mr-2 text-pitchpro-accent" /> Y Combinator Prep
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Users class="h-5 w-5 mr-2 text-pitchpro-accent" /> Hackathon Hubs
        </span>
        <span class="font-heading font-bold text-lg sm:text-xl text-gray-300 hover:text-white transition-colors tracking-tight flex items-center shrink-0">
          <Compass class="h-5 w-5 mr-2 text-pitchpro-accent" /> Techstars Alumni
        </span>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-20 sm:py-28 bg-[#0B0B0F] border-b border-white/10 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20">
        <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-white mb-4">
          From Raw Ideas to Pitch Winner
        </h2>
        <p class="text-base sm:text-lg text-gray-400">
          Four simple steps to transform messy technical concepts or simple descriptions into structured, polished decks and practiced presentations.
        </p>
      </div>

      <!-- 4-Step Grid Flow -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        <!-- Connecting Line (Large screen only) -->
        <div class="hidden lg:block absolute top-[52px] left-[15%] right-[15%] h-0.5 bg-gradient-to-r from-pitchpro-accent/20 via-pitchpro-success/20 to-pitchpro-accent/20 -z-10"></div>
        
        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center p-5 group">
          <div class="w-16 h-16 rounded-2xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-5 group-hover:bg-pitchpro-accent group-hover:text-white transition-all duration-300 shadow-sm">
            <FileText class="h-7 w-7" />
          </div>
          <span class="text-xs font-bold text-pitchpro-accent uppercase tracking-wider mb-2">Step 1</span>
          <h3 class="text-lg font-heading font-bold text-white mb-2">Upload Concept</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Drag in your research paper, project PDF, draft document, or write a summary.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center p-5 group">
          <div class="w-16 h-16 rounded-2xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-5 group-hover:bg-pitchpro-accent group-hover:text-white transition-all duration-300 shadow-sm">
            <Sparkles class="h-7 w-7" />
          </div>
          <span class="text-xs font-bold text-pitchpro-accent uppercase tracking-wider mb-2">Step 2</span>
          <h3 class="text-lg font-heading font-bold text-white mb-2">AI Analyzes</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            AI evaluates problems, business models, market sizing, and structures the narrative.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center p-5 group">
          <div class="w-16 h-16 rounded-2xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-5 group-hover:bg-pitchpro-accent group-hover:text-white transition-all duration-300 shadow-sm">
            <Layers class="h-7 w-7" />
          </div>
          <span class="text-xs font-bold text-pitchpro-accent uppercase tracking-wider mb-2">Step 3</span>
          <h3 class="text-lg font-heading font-bold text-white mb-2">Generate Output</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Get slides layout, bullet points, scripts, executive summaries, and exports.
          </p>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col items-center text-center p-5 group">
          <div class="w-16 h-16 rounded-2xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-5 group-hover:bg-pitchpro-accent group-hover:text-white transition-all duration-300 shadow-sm">
            <Mic class="h-7 w-7" />
          </div>
          <span class="text-xs font-bold text-pitchpro-accent uppercase tracking-wider mb-2">Step 4</span>
          <h3 class="text-lg font-heading font-bold text-white mb-2">Practice Coach</h3>
          <p class="text-sm text-gray-400 leading-relaxed">
            Rehearse speaking into your mic to score clarity, pace, and prepare with judge Q&A.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- Core Features Bento Box Grid -->
  <section id="features" class="py-20 sm:py-28 bg-[#111116] border-b border-white/10 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20">
        <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-white mb-4">
          All-in-One Pitch Preparation Engine
        </h2>
        <p class="text-base sm:text-lg text-gray-400">
          Ditch the formatting pain. PitchPro equips you with tools to master the deck design, storytelling flow, and presentation day response.
        </p>
      </div>

      <!-- Bento Box Layout Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Bento Card 1: AI Slide Deck Generator (Large Grid Spanning 2 Cols) -->
        <div class="bg-[#0B0B0F] rounded-2xl border border-white/10 p-6 md:p-8 md:col-span-2 shadow-sm hover:shadow-md hover:border-white/20 transition-all flex flex-col group overflow-hidden relative">
          <div class="absolute -right-10 -bottom-10 w-44 h-44 bg-pitchpro-accent/5 rounded-full pointer-events-none group-hover:scale-110 transition-transform"></div>
          <div>
            <div class="h-12 w-12 rounded-xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-6">
              <Layers class="h-6 w-6" />
            </div>
            <h3 class="text-xl font-heading font-bold text-white mb-3">AI Slide Deck Generator</h3>
            <p class="text-gray-400 text-sm max-w-xl mb-6">
              Skip starting from a blank page. Our slide generator instantly drafts 8-12 beautiful slides mapping the classic venture sequence: Problem, Solution, Business Model, TAM, Competitors, and Call-to-action.
            </p>
            
            <!-- Small interactive slider representation -->
            <div class="space-y-2 border border-white/5 rounded-lg p-3 bg-white/[0.02] text-[11px] font-mono">
              <div class="flex justify-between items-center">
                <span class="text-gray-500">Structure Configurator</span>
                <span class="bg-pitchpro-accent/10 text-pitchpro-accent px-1.5 py-0.5 rounded text-[9px] font-bold">10 Slides</span>
              </div>
              <div class="flex items-center space-x-2">
                <div class="h-1.5 w-1/4 rounded-full bg-pitchpro-accent"></div>
                <div class="h-1.5 w-1/4 rounded-full bg-pitchpro-accent"></div>
                <div class="h-1.5 w-1/4 rounded-full bg-pitchpro-accent"></div>
                <div class="h-1.5 w-1/4 rounded-full bg-white/10"></div>
              </div>
              <div class="text-gray-500 text-[10px]">
                Active theme: <span class="text-white font-bold">Cyber Obsidian Black</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Bento Card 2: AI Story Builder (1 Col) -->
        <div class="bg-[#0B0B0F] rounded-2xl border border-white/10 p-6 md:p-8 shadow-sm hover:shadow-md hover:border-white/20 transition-all flex flex-col group">
          <div>
            <div class="h-12 w-12 rounded-xl bg-pitchpro-accent/5 border border-pitchpro-accent/15 flex items-center justify-center text-pitchpro-accent mb-6">
              <Sparkles class="h-6 w-6" />
            </div>
            <h3 class="text-xl font-heading font-bold text-white mb-3">AI Story Builder</h3>
            <p class="text-gray-400 text-sm mb-6">
              Ensures your slides connect logically. Our AI frames your startup around standard narrative arcs: "The Visionary Leap," "The Data-Driven Pivot," or "The Market Disruptor."
            </p>
          </div>
        </div>

        <!-- Bento Card 3: AI Rehearsal Coach (1 Col) -->
        <div class="bg-[#0B0B0F] rounded-2xl border border-white/10 p-6 md:p-8 shadow-sm hover:shadow-md hover:border-white/20 transition-all flex flex-col group">
          <div>
